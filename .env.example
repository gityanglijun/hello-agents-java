# LLM 配置
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_ID=deepseek-v4-flash

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 高德地图 API Key
AMAP_API_KEY=your-amap-api-key

# Unsplash 图片搜索
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

#搜索SERPAPI
SERPAPI_API_KEY=your-serpapi-api-key

TAVILY_API_KEY=your-tavily-api-key

MODELSCOPE_API_KEY="your-llm-api-key"

# ==================== 存储后端 ====================
# VECTOR_STORE_TYPE=inmemory  (默认，内存+JSON)
# VECTOR_STORE_TYPE=qdrant     (需要 docker run -p 6333:6333 qdrant/qdrant)
VECTOR_STORE_TYPE=inmemory

# Qdrant 地址（VECTOR_STORE_TYPE=qdrant 时需要）
QDRANT_URL=http://localhost:6333

# GRAPH_STORE_TYPE=inmemory   (默认，内存+JSON)
# GRAPH_STORE_TYPE=neo4j       (需要 docker run -p 7687:7687 -e NEO4J_AUTH=neo4j/password neo4j:5)
GRAPH_STORE_TYPE=inmemory

# Neo4j 连接信息（GRAPH_STORE_TYPE=neo4j 时需要）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ==================== Game Research Agent ====================
# Spring Boot VIP 项目 MCP Server 连接方式（二选一）：

# 方式1 (推荐，生产环境): SSE 远程连接 — Agent 和 Spring Boot 部署在不同服务器
# Spring Boot 端无需任何额外配置，启动 Web 服务器即可
# 例: GAME_MCP_URL=http://your-server:8080
GAME_MCP_URL=http://your-server:8080

# 方式2 (本地开发): Stdio 子进程 — Agent 启动 Spring Boot JAR
# mvn package -DskipTests 后把 JAR 路径填这里
# 例: GAME_MCP_JAR_PATH=E:/vip-project/backend/target/vip-backend-0.0.1-SNAPSHOT.jar
GAME_MCP_JAR_PATH=
GAME_MCP_JAVA_HOME=
