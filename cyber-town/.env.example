# ===== LLM 配置 =====
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_ID=gpt-4o

# ===== 向量存储 (Qdrant) =====
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ===== 图存储 (Neo4j) =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ===== 数据库 =====
SQLITE_PATH=data/cyber_town.db

# ===== 服务器 =====
SERVER_PORT=8080
